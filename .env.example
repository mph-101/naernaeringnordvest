# Supabase
VITE_SUPABASE_PROJECT_ID=        # Prosjekt-ID fra Supabase dashboard
VITE_SUPABASE_URL=               # https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=   # anon/public key fra Supabase → Settings → API

# Stripe (klient-token for checkout)
VITE_PAYMENTS_CLIENT_TOKEN=      # pk_test_... fra Stripe dashboard

# Next.js (samme verdier som Vite, med NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=        # https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # anon/public key (samme som VITE_SUPABASE_PUBLISHABLE_KEY)
